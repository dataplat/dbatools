name: Example - Test with Preview Version
# This is an example workflow showing how to use a preview version from a remote branch
# To use: rename this file to remove .example extension and commit

on:
  workflow_dispatch:
    inputs:
      remote-branch:
        description: 'Remote branch containing version file (e.g., preview-2024.5.1)'
        required: false
        type: string
      dbatools-library-version:
        description: 'Direct version override (takes precedence over branch)'
        required: false
        type: string

defaults:
  run:
    shell: pwsh

jobs:
  test-preview:
    runs-on: ubuntu-latest
    env:
      GITHUB_TOKEN: ${{secrets.GITHUB_TOKEN}}

    steps:
      - uses: actions/checkout@v3

      - name: Get dbatools.library version
        id: version
        run: |
          # This demonstrates using the script with remote branch support
          $params = @{}
          if ('${{ github.event.inputs.dbatools-library-version }}') {
            $params.WorkflowInputVersion = '${{ github.event.inputs.dbatools-library-version }}'
          }
          if ('${{ github.event.inputs.remote-branch }}') {
            $params.RemoteBranch = '${{ github.event.inputs.remote-branch }}'
          }
          
          $version = & ./.github/scripts/Get-DbatoolsLibraryVersion.ps1 @params
          "version=$version" | Out-File -FilePath $env:GITHUB_OUTPUT -Encoding utf8 -Append

      - name: Install and cache PowerShell modules
        uses: potatoqualitee/psmodulecache@v6.2.1
        with:
          modules-to-cache: dbatools.library:${{ steps.version.outputs.version }}

      - name: Test module import
        run: |
          Import-Module ./dbatools.psd1 -Force
          $lib = Get-Module dbatools.library
          Write-Host "Successfully loaded dbatools.library version: $($lib.Version)"